# ============================================================
# Multi-Model Brand Impersonation Detection System - ENV CONFIG
# ============================================================

# --- Google Gemini (FREE at aistudio.google.com/app/apikey) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash   # Free tier model

# --- HuggingFace (FREE at huggingface.co/settings/tokens) ---
HF_API_TOKEN=your_hf_token_here
HF_INFERENCE_URL=https://api-inference.huggingface.co/models

# --- Django Settings ---
SECRET_KEY=your_django_secret_key_here_change_in_production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (SQLite for dev, PostgreSQL for prod) ---
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=yourpassword

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:8501

# --- Frontend ---
BACKEND_URL=http://localhost:8000
